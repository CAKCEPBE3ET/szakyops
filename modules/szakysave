run_szakysave() {
    set +e

    CONFIG_FILE="/opt/szakyops/config/szakyops.conf"
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    else
        echo -e "\n\033[1;31mError: Configuration file not found! Please run 'Backup Setup' first.\033[0m"
        return 1
    fi

    C_DEF='\e[0m'
    C_RED='\e[1;31m'
    C_GRN='\e[1;32m'
    C_YEL='\e[1;33m'
    C_CYN='\e[1;36m'
    C_BOLD='\e[1m'

    W_L=34
    W_M_VAL=10
    LINE_LEN=88

    print_line_eq() { printf "${C_CYN}${C_BOLD}%${LINE_LEN}s${C_DEF}\n" "" | tr ' ' '='; }
    print_line_dash() { printf "${C_CYN}%${LINE_LEN}s${C_DEF}\n" "" | tr ' ' '-'; }

    print_row() {
        local emoji="$1"
        local title="$2"
        local lbl1="$3"
        local val1="$4"
        local lbl2="$5"
        local val2="$6"
        printf " %b  ${C_CYN}%-${W_L}s${C_DEF} | ${C_YEL}%-6s${C_DEF} %-${W_M_VAL}b | ${C_YEL}%-7s${C_DEF} %b\n" "$emoji" "$title" "$lbl1" "$val1" "$lbl2" "$val2"
    }

    check_internet() {
        if ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1; then
            print_row "🌐" "Network (Internet)" "State:" "${C_GRN}Online${C_DEF}" "Ping:" "8.8.8.8"
        else
            print_row "🌐" "Network (Internet)" "State:" "${C_RED}Offline${C_DEF}" "Ping:" "Failed"
            return 1
        fi
    }

    wait_for_host() {
        if [ "$USE_WOL" != "true" ]; then
            print_row "📡" "Target Status" "WOL:" "${C_YEL}Disabled${C_DEF}" "Action:" "Skipping Wake"
            return 0
        fi

        print_row "📡" "Waking up Target" "Host:" "$TARGET" "MAC:" "$TARGET_MAC"
        wakeonlan "$TARGET_MAC" >/dev/null 2>&1

        local max_attempts=40
        local attempt=1

        while [ $attempt -le $max_attempts ]; do
            if ping -c 1 -W 1 "$TARGET" > /dev/null 2>&1; then
                print_row "✅" "Target Status" "State:" "${C_GRN}Alive${C_DEF}" "Wait:" "$((attempt * 2)) sec"
                return 0
            fi
            sleep 2
            ((attempt++))
        done

        print_row "❌" "Target Status" "State:" "${C_RED}Offline${C_DEF}" "Wait:" "Timeout"
        return 1
    }

    do_backup() {
        #Created v1.1.0
        exec 200>/tmp/szakyops.lock
        flock -n 200 || {
            echo -e "${C_RED}Another backup session is already running!${C_DEF}"
            return 1
        }
        ###############
        local TIMESTAMP=$(date '+%Y-%m-%d_%H-%M-%S')
        local TIMESTAMP_DEST="$TARGET_DEST/$TIMESTAMP"
        local SRC_COUNT="${#SOURCES[@]}"

        print_row "🔄" "Backup Process" "Sources:" "${SRC_COUNT} items" "Dest:" "$TIMESTAMP_DEST"

        echo -e " ${C_CYN}--- [ Target Sources ] ---${C_DEF}"
        for src in "${SOURCES[@]}"; do
            echo -e "  ${C_YEL}📁${C_DEF} $src"
        done

        ssh -i "$TARGET_SSH_KEY" -o StrictHostKeyChecking=no "$TARGET_USER@$TARGET" "mkdir -p \"$TIMESTAMP_DEST\""

        local RAW_PREV=$(ssh -i "$TARGET_SSH_KEY" -o StrictHostKeyChecking=no "$TARGET_USER@$TARGET" "ls -1d $TARGET_DEST/20* 2>/dev/null | grep -v '$TIMESTAMP' | sort -V | tail -n 1")
        local PREV_DIR=$(echo "$RAW_PREV" | tr -d '\r' | tr -d '\n')

        local LINK_DEST_ARG=""
        if [ -n "$PREV_DIR" ]; then
            local PREV_BASE=$(basename "$PREV_DIR")
            echo -e "${C_CYN}Linking against previous backup: $PREV_BASE (Zero-space transfer!)${C_DEF}"
            LINK_DEST_ARG="--link-dest=../$PREV_BASE"
        else
            echo -e "${C_YEL}No previous backup found. Full transfer will occur!${C_DEF}"
        fi

        #CREATED v1.1.0
        local RUNNING_DB_CONTAINERS=$(sudo -n docker ps --filter "status=running" --format "{{.Names}}" 2>/dev/null | grep -E -i "db|mysql|postgres|mariadb|redis|mongo" || true)
        local RUNNING_NATIVE_DBS=$(systemctl list-units --type=service --state=running 2>/dev/null | grep -E -i "mysql|postgresql|mariadb|redis|mongod" | awk '{print $1}' || true)

        cleanup_databases(){
            if [ "${RSYNC_EXIT:-1}" -ne 0 ] && [ -n "$TIMESTAMP_DEST" ]; then
                echo -e "\n${C_RED}⚠️ Backup interrupted/failed! Cleaning up incomplete backup on target...${C_DEF}"

                if [ "$IS_WINDOWS" == "true" ]; then
                    local WIN_CLEAN_PATH=$(echo "$TIMESTAMP_DEST" | sed -E 's/^\/([a-zA-Z])\//\1:\\/' | tr '/' '\\')
                    ssh -n -i "$TARGET_SSH_KEY" -o StrictHostKeyChecking=no "$TARGET_USER@$TARGET" "powershell -Command \"Remove-Item -Recurse -Force '$WIN_CLEAN_PATH' -ErrorAction SilentlyContinue\"" 2>/dev/null || true
                else
                    ssh -n -i "$TARGET_SSH_KEY" -o StrictHostKeyChecking=no "$TARGET_USER@$TARGET" "rm -rf \"$TIMESTAMP_DEST\"" 2>/dev/null || true
                fi
                TIMESTAMP_DEST=""
            fi

            if [ -n "$RUNNING_DB_CONTAINERS" ]; then
                echo -e "${C_GRN}▶️  Restarting Docker databases...${C_DEF}"
                echo "$RUNNING_DB_CONTAINERS" | xargs -r -d '\n' sudo -n docker start >/dev/null 2>&1
            fi

            if [ -n "$RUNNING_NATIVE_DBS" ]; then
                echo -e "${C_GRN}▶️  Restarting native databases...${C_DEF}"
                echo "$RUNNING_NATIVE_DBS" | xargs -r -d '\n' sudo -n systemctl start >/dev/null 2>&1
            fi
        }

        trap cleanup_databases EXIT INT TERM

        if [ -n "$RUNNING_DB_CONTAINERS" ] || [ -n "$RUNNING_NATIVE_DBS" ]; then
            echo -e "${C_YEL}⏸️  Shutting down live databases (Cold Backup)...${C_DEF}"

            if [ -n "$RUNNING_DB_CONTAINERS" ]; then
                echo -e "  ${C_CYN}Shutting down Docker DBs:${C_DEF} $(echo $RUNNING_DB_CONTAINERS | tr '\n' ' ')"
                echo "$RUNNING_DB_CONTAINERS" | xargs -r -d '\n' sudo -n docker stop >/dev/null 2>&1
            fi

            if [ -n "$RUNNING_NATIVE_DBS" ]; then
                echo -e "  ${C_CYN}Shutting down Native DBs:${C_DEF} $(echo $RUNNING_NATIVE_DBS | tr '\n' ' ')"
                echo "$RUNNING_NATIVE_DBS" | xargs -r -d '\n' sudo -n systemctl stop >/dev/null 2>&1
            fi
        fi
        ################################

        echo -e "${C_YEL}--- [ Rsync Transfer Progress ] ---${C_DEF}"

        if [ "$IS_WINDOWS" == "true" ]; then
            rsync -rtvR \
                --info=progress2,flist2 \
                --no-compress \
                --no-owner \
                --no-group \
                --no-perms \
                --no-links \
                --size-only \
                --modify-window=2 \
                --iconv=utf-8,utf-8 \
                $LINK_DEST_ARG \
                -e "ssh -i $TARGET_SSH_KEY -o StrictHostKeyChecking=no" \
                --rsync-path="\"$WIN_RSYNC_PATH\"" \
                "${SOURCES[@]}" \
                "$TARGET_USER@$TARGET:$TIMESTAMP_DEST"
        else
            rsync -aR \
                --info=progress2 \
                --no-compress \
                --no-owner \
                --no-group \
                --no-perms \
                --modify-window=2 \
                --iconv=utf-8,utf-8 \
                $LINK_DEST_ARG \
                -e "ssh -i $TARGET_SSH_KEY -o StrictHostKeyChecking=no" \
                "${SOURCES[@]}" \
                "$TARGET_USER@$TARGET:$TIMESTAMP_DEST"
        fi

        local RSYNC_EXIT=$?
        #Created v1.1.0
        cleanup_databases
        trap - EXIT INT TERM
        ####################

        echo -e "\n${C_YEL}-----------------------------------${C_DEF}"

        if [ $RSYNC_EXIT -eq 0 ]; then
            print_row "💾" "Rsync Status" "Result:" "${C_GRN}Success${C_DEF}" "Exit:" "0"
            test_restore "$TIMESTAMP_DEST"
        else
            print_row "💾" "Rsync Status" "Result:" "${C_RED}Failed${C_DEF}" "Exit:" "$RSYNC_EXIT"
        fi
    }

    test_restore() {
        local REMOTE_DEST="$1"
        if [ -z "$REMOTE_DEST" ]; then return; fi

        echo -e " ${C_CYN}--- [ Random Restore Verification (Target -> Local) ] ---${C_DEF}"
        print_row "🔍" "Scanning Target" "Path:" "${REMOTE_DEST:0:12}..." "Action:" "Selecting 3 files"

        local REMOTE_FILES=$(ssh -i "$TARGET_SSH_KEY" -o StrictHostKeyChecking=no "$TARGET_USER@$TARGET" \
            "find \"$REMOTE_DEST\" -type f -size -50M 2>/dev/null | head -n 300 | shuf -n 3")

        if [ -z "$REMOTE_FILES" ]; then
            print_row "⚠️" "Restore Test" "Status:" "No file found" "Action:" "Aborting test"
            return
        fi

        local RESTORE_TMP="/tmp/backup_test"
        mkdir -p "$RESTORE_TMP"

        local SUCCESS_COUNT=0
        local TOTAL_COUNT=0

        while IFS= read -r REMOTE_FILE; do
            [ -z "$REMOTE_FILE" ] && continue
            REMOTE_FILE=$(echo "$REMOTE_FILE" | tr -d '\r' | tr -d '\n')
            ((TOTAL_COUNT++))

            local DISP_NAME=$(basename "$REMOTE_FILE")
            local LOCAL_ORIGINAL="${REMOTE_FILE#$REMOTE_DEST}"

            local FILE_SIZE=$(ssh -n -i "$TARGET_SSH_KEY" -o StrictHostKeyChecking=no "$TARGET_USER@$TARGET" "du -h \"$REMOTE_FILE\"" 2>/dev/null | cut -f1 || echo "N/A")
            FILE_SIZE=$(echo "$FILE_SIZE" | tr -d '\r' | tr -d '\n')

            print_row "🎲" "Restore Target #$TOTAL_COUNT" "File:" "${C_YEL}${DISP_NAME:0:10}${C_DEF}" "Size:" "$FILE_SIZE"

            local RESTORED_FILE="$RESTORE_TMP/$DISP_NAME"
            rm -f "$RESTORED_FILE"

            if [ "$IS_WINDOWS" == "true" ]; then
                rsync -a \
                    -e "ssh -i $TARGET_SSH_KEY -o StrictHostKeyChecking=no" \
                    --rsync-path="\"$WIN_RSYNC_PATH\"" \
                    "$TARGET_USER@$TARGET:$REMOTE_FILE" \
                    "$RESTORE_TMP/" < /dev/null >/dev/null 2>&1
            else
                rsync -a \
                    -e "ssh -i $TARGET_SSH_KEY -o StrictHostKeyChecking=no" \
                    "$TARGET_USER@$TARGET:$REMOTE_FILE" \
                    "$RESTORE_TMP/" < /dev/null >/dev/null 2>&1
            fi

            local RESTORE_EXIT=$?

            if [ $RESTORE_EXIT -eq 0 ] && [ -f "$RESTORED_FILE" ]; then
                if [ -f "$LOCAL_ORIGINAL" ]; then
                    local HASH_ORIG=$(md5sum "$LOCAL_ORIGINAL" | awk '{print $1}')
                    local HASH_REST=$(md5sum "$RESTORED_FILE" | awk '{print $1}')

                    if [ "$HASH_ORIG" == "$HASH_REST" ]; then
                        print_row "✅" "Data Integrity #$TOTAL_COUNT" "Status:" "${C_GRN}Match${C_DEF}" "Hash:" "${HASH_REST:0:6}..."
                        ((SUCCESS_COUNT++))
                    else
                        print_row "❌" "Data Integrity #$TOTAL_COUNT" "Status:" "${C_RED}Mismatch${C_DEF}" "Hash:" "Error"
                    fi
                else
                    print_row "⚠️" "Data Integrity #$TOTAL_COUNT" "Status:" "${C_YEL}No Original${C_DEF}" "Note:" "Pulled ok"
                    ((SUCCESS_COUNT++))
                fi
            else
                print_row "❌" "Restore Status #$TOTAL_COUNT" "Status:" "${C_RED}Failed${C_DEF}" "Exit:" "$RESTORE_EXIT"
            fi

            rm -f "$RESTORED_FILE"

        done <<< "$REMOTE_FILES"

        rm -rf "$RESTORE_TMP"
    }

    shutdown_host() {
        if [ "$USE_WOL" != "true" ]; then
            print_row "🔌" "Shutdown Target" "WOL:" "${C_YEL}Disabled${C_DEF}" "Action:" "Skipping Shutdown"
            return 0
        fi

        local SHUTDOWN_CMD="sudo poweroff"
        if [ "$IS_WINDOWS" == "true" ]; then
            SHUTDOWN_CMD="shutdown -s -f -t 10"
        fi

        print_row "🔌" "Shutdown Target" "Host:" "$TARGET" "Action:" "PowerOff"
        ssh -i "$TARGET_SSH_KEY" -o StrictHostKeyChecking=no "$TARGET_USER@$TARGET" "$SHUTDOWN_CMD" >/dev/null 2>&1

        local max_attempts=20
        local attempt=1

        while ping -c 1 -W 1 "$TARGET" > /dev/null 2>&1; do
            sleep 5
            ((attempt++))
            if [ $attempt -gt $max_attempts ]; then
                print_row "⚠️" "Shutdown Status" "State:" "${C_YEL}Timeout${C_DEF}" "Ping:" "Alive"
                return 1
            fi
        done

        print_row "💤" "Shutdown Status" "State:" "${C_GRN}Dead${C_DEF}" "Ping:" "Unreach"
    }

    if [ "$IS_CRON" != "true" ]; then clear; fi
    print_line_eq

    local ACTUAL_USER="${SUDO_USER:-$USER}"
    if [[ "$TARGET_SSH_KEY" == "/root/.ssh/id_ed25519" ]]; then
        TARGET_SSH_KEY="/home/$ACTUAL_USER/.ssh/id_ed25519"
    fi

    HDR_TEXT="=== 🚀 Backup Session Report: $(date '+%Y-%m-%d %H:%M:%S')"
    PAD_LEN=$(( LINE_LEN - ${#HDR_TEXT} - 4 ))
    printf "${C_CYN}${C_BOLD}%s%${PAD_LEN}s===${C_DEF}\n" "$HDR_TEXT" ""

    print_line_eq

    check_internet
    print_line_dash

    if wait_for_host; then
        if [ "$IS_WINDOWS" == "true" ]; then
            print_row "🔍" "Detecting Rsync" "Host:" "$TARGET" "Action:" "Searching"
            WIN_RSYNC_PATH=$(ssh -n -i "$TARGET_SSH_KEY" -o StrictHostKeyChecking=no "$TARGET_USER@$TARGET" "where rsync 2>nul || where /r \"C:\Program Files\" rsync.exe 2>nul" | head -n 1 | tr -d '\r' | tr -d '\n')

            if [ -z "$WIN_RSYNC_PATH" ]; then
                WIN_RSYNC_PATH="C:\Program Files\Git\usr\bin\rsync.exe"
            fi
        fi
        print_line_dash
        do_backup
        print_line_dash
        shutdown_host
    fi

    print_line_eq
    if [ "$IS_CRON" == "true" ]; then
        echo -e "\n\n"
    fi

    set -e
}
