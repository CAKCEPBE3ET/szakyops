set -e

SCRIPT_DIR=$(dirname "$(realpath "$0")")

if [[ -f "/opt/szakyops/config/szakyops.conf" ]]; then
    source "/opt/szakyops/config/szakyops.conf"
fi

if [[ -f "$SCRIPT_DIR/modules/szakyfetch" ]]; then
    source "$SCRIPT_DIR/modules/szakyfetch"
fi

if [[ -f "$SCRIPT_DIR/modules/szakysave" ]]; then
    source "$SCRIPT_DIR/modules/szakysave"
fi

if [[ -f "$SCRIPT_DIR/modules/szakycron" ]]; then
    source "$SCRIPT_DIR/modules/szakycron"
fi
if [[ -f "$SCRIPT_DIR/modules/szakylog" ]]; then
    source "$SCRIPT_DIR/modules/szakylog"
fi

BLUE='\0033[0;34m'
GREEN='\0033[0;32m'
YELLOW='\0033[1;33m'
RED='\0033[0;31m'
NC='\0033[0m'

C_DEF='\033[0m'
C_RED='\033[1;31m'
C_GRN='\033[1;32m'
C_YEL='\033[1;33m'
C_CYN='\033[1;36m'
C_BOLD='\033[1m'

LINE_LEN=98

print_line_eq() { printf "${C_CYN}${C_BOLD}%${LINE_LEN}s${C_DEF}\n" "" | tr ' ' '='; }

print_header() {
    clear
    print_line_eq
    local TITLE="🎒 SZAKYOPS: Server Management & Backup Toolkit 🎒"
    local TITLE_LEN=${#TITLE}
    local PAD_TOTAL=$(( LINE_LEN - TITLE_LEN - 6 ))
    local PAD_LEFT=$(( PAD_TOTAL / 2 ))
    local PAD_RIGHT=$(( PAD_TOTAL - PAD_LEFT ))
    printf "${C_CYN}${C_BOLD}===%${PAD_LEFT}s%s%${PAD_RIGHT}s===${C_DEF}\n" "" "$TITLE" ""
    print_line_eq
}

show_menu() {
    while true; do
        print_header
        printf "  [1] ${C_CYN}%-20s${C_DEF} | %s\n" "SusStat" "View system statistics (Fetch)"
        printf "  [2] ${C_CYN}%-20s${C_DEF} | %s\n" "Backup Setup" "Configure backup targets & sources"
        printf "  [3] ${C_CYN}%-20s${C_DEF} | %s\n" "Run Backup Now" "Execute backup immediately"
        printf "  [4] ${C_CYN}%-20s${C_DEF} | %s\n" "Cron Manager" "Schedule backups via Crontab"
        printf "  [5] ${C_CYN}%-20s${C_DEF} | %s\n" "View Logs" "Check backup and system logs"
        printf "  [6] ${C_RED}%-20s${C_DEF} | %s\n" "Exit" "Close Szakyops"
        print_line_eq
        echo ""
        read -r -p "Please select an option [1-6]: " CHOICE

        case "$CHOICE" in
            1)
                if declare -f run_szakyfetch > /dev/null; then
                    clear
                    run_szakyfetch
                else
                    print_header
                    echo -e "${C_RED}Error: Fetch module function not found!${C_DEF}"
                fi
                echo ""
                read -r -p "Press [Enter] to return to the main menu..."
                ;;
            2)
                print_header
                if [[ -f "$SCRIPT_DIR/modules/szakysetup" ]]; then
                    bash "$SCRIPT_DIR/modules/szakysetup"
                else
                    echo -e "${C_RED}Error: Setup script not found!${C_DEF}"
                fi
                echo ""
                read -r -p "Press [Enter] to return to the main menu..."
                ;;
            3)
                if declare -f run_szakysave > /dev/null; then
                    clear
                    run_szakysave
                else
                    print_header
                    echo -e "${C_RED}Error: Save module function not found!${C_DEF}"
                fi
                echo ""
                read -r -p "Press [Enter] to return to the main menu..."
                ;;
            4)
                if declare -f run_szakycron > /dev/null; then
                    run_szakycron
                else
                    print_header
                    echo -e "${C_RED}Error: Cron module function not found!${C_DEF}"
                fi
                echo ""
                read -r -p "Press [Enter] to return to the main menu..."
                ;;
            5)
                if declare -f run_szakylog > /dev/null; then
                    run_szakylog
                else
                    print_header
                    echo -e "${C_RED}Error: Log module function not found!${C_DEF}"
                fi
                echo ""
                read -r -p "Press [Enter] to return to the main menu..."
                ;;
            6)
                echo -e "\n${C_YEL}Goodbye from Szakyops!${C_DEF}\n"
                exit 0
                ;;
            *)
                echo -e "\n${C_RED}Invalid option!${C_DEF} Please choose between 1 and 6."
                sleep 2
                ;;
        esac
    done
}

case "$1" in
    --fetch)
        if declare -f run_szakyfetch > /dev/null; then
            if [ "$IS_CRON" != "true" ]; then clear; fi
            run_szakyfetch
            if [ "$IS_CRON" == "true" ]; then
                echo -e "\n\n"
            fi
        else
            echo "Fetch module not loaded."
            exit 1
        fi
        ;;
    --install)
        if [[ -f "$SCRIPT_DIR/install.sh" ]]; then
            echo -e "\n📦 Starting Szakyops installation from local repository..."
            exec sudo bash "$SCRIPT_DIR/install.sh"
        else
            echo -e "\n📦 Starting Szakyops installation from GitHub..."
            if curl -sSL https://raw.githubusercontent.com/CAKCEPBE3ET/Szakyops/main/install.sh -o /tmp/szakyops_install.sh; then
                exec sudo bash /tmp/szakyops_install.sh
            else
                echo "Error: Failed to download install.sh from GitHub."
                exit 1
            fi
        fi
        ;;
    --uninstall)
        if [[ -f "/opt/szakyops/uninstall.sh" ]]; then
            echo -e "\n🗑️  Starting Szakyops uninstallation..."
            exec sudo bash /opt/szakyops/uninstall.sh
        else
            if [[ $EUID -ne 0 ]]; then
                echo "Uninstalling requires root privileges. Re-running with sudo..."
                exec sudo bash "$0" --uninstall
            fi
            rm -f "/usr/local/bin/szakyops"
            rm -rf "/opt/szakyops"
            echo "Szakyops uninstalled successfully."
            exit 0
        fi
        ;;
    --help|-h)
        echo -e "\n🎒 SZAKYOPS - Server Management Toolkit"
        echo "Usage: szakyops [OPTION]"
        echo ""
        echo "Options:"
        echo "  --install    Run the installer (must be executed inside the source folder)"
        echo "  --uninstall  Remove Szakyops from the system completely"
        echo "  --fetch      Run system statistics collection immediately"
        echo "  --help, -h   Show this help message"
        echo ""
        exit 0
        ;;
    "")
        show_menu
        ;;
    *)
        echo "Usage: szakyops [--install | --uninstall | --fetch | --help]"
        exit 1
        ;;
esac
